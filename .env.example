# ─── APP ───────────────────────────────────────────
APP_NAME="PQRS Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ─── BASE DE DATOS ─────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=pqrs_db
DB_USERNAME=pqrs_user
DB_PASSWORD=pqrs_secret

# ─── N8N ───────────────────────────────────────────
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=true
# Evita problemas de cookies en el navegador al usar http
N8N_SECURE_COOKIE=false
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin123
WEBHOOK_URL=http://localhost:5678

# ─── OPENAI ────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── LARAVEL INTERNO ───────────────────────────────
SESSION_DRIVER=cookie
QUEUE_CONNECTION=sync
