# ─── APP ───────────────────────────────────────────
APP_NAME="PQRS UTS"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://ip_elastica        # <- Cambia por tu IP elástica

# ─── BASE DE DATOS ─────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=     # <- Cambia por una contraseña segura

# ─── N8N ───────────────────────────────────────────
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=  # <- Cambia esto
WEBHOOK_URL=http://ip_elastica:5678 # <- Tu IP elástica

# ─── OPENAI ────────────────────────────────────────
OPENAI_API_KEY=sk-...               # <- Tu clave de OpenAI

# ─── LARAVEL INTERNO ───────────────────────────────
APP_KEY=                            # <- Se genera después con artisan
SESSION_DRIVER=cookie
QUEUE_CONNECTION=sync